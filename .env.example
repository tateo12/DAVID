# Sentinel Configuration
ANTHROPIC_API_KEY=your-key-here
DATABASE_URL=sqlite:///sentinel.db

# Optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Model Configuration (cost control)
L2_MODEL=claude-haiku-4-5-20251001
L3_MODEL=claude-sonnet-4-6
MAX_DAILY_LLM_BUDGET_USD=5.00
L2_CONFIDENCE_THRESHOLD=0.7
L3_ESCALATION_THRESHOLD=0.5
