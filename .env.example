# Sentinel Configuration
#
# Local setup:
#   1) Copy this file to backend/.env
#   2) Copy frontend/.env.local.example to frontend/.env.local (NEXT_PUBLIC_API_BASE=http://localhost:8000)
#
# LLM / OpenRouter:
#   Without OPENROUTER_API_KEY the app still runs (L1 regex, dashboards, curriculum UI). Heuristic fallbacks are used
#   where an LLM is optional (e.g. weekly learning study page). Set your key here when testing full L2/L3, skill
#   analysis, Scout, and generated weekly learning content.
#
ANTHROPIC_API_KEY=your-key-here
OPENROUTER_API_KEY=
# Comma-separated; first origin is used for email links. CORS allows these origins.
# Local dev:      ALLOWED_ORIGINS=http://localhost:3000
# Production:     ALLOWED_ORIGINS=https://sentinel-ai-security.com
# NEVER use * in production — it exposes all endpoints to any origin.
ALLOWED_ORIGINS=http://localhost:3000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=sqlite:///sentinel.db

# SMTP — leave SMTP_HOST empty to disable real email (uses DB queue instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=sentinel@company.com
SMTP_USE_TLS=true
ALERT_EMAIL=security-team@company.com

# Model Configuration (cost control)
L2_MODEL_NAME=google/gemma-3-4b-it:free
L3_MODEL_NAME=nvidia/nemotron-nano-12b-v2-vl:free
SKILL_MODEL_NAME=google/gemma-3-4b-it:free
ENABLE_L2=true
ENABLE_L3=true
DAILY_BUDGET_USD=5.00
L1_CONFIDENCE_THRESHOLD=0.8
L2_CONFIDENCE_THRESHOLD=0.7

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# First login: when the users table is empty, one manager account is created from these (then remove or leave blank).
SENTINEL_INITIAL_ADMIN_USERNAME=admin
SENTINEL_INITIAL_ADMIN_PASSWORD=changeme
