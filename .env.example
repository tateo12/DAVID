# Sentinel Configuration
ANTHROPIC_API_KEY=your-key-here
OPENROUTER_API_KEY=your-openrouter-key
# Comma-separated; first origin is used for email links. CORS allows these origins (use * as single value for allow-all).
ALLOWED_ORIGINS=http://localhost:3000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=sqlite:///sentinel.db

# SMTP — leave SMTP_HOST empty to disable real email (uses DB queue instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=sentinel@company.com
SMTP_USE_TLS=true
ALERT_EMAIL=security-team@company.com

# Model Configuration (cost control)
L2_MODEL_NAME=nvidia/nemotron-nano-9b-v2:free
L3_MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free
SKILL_MODEL_NAME=nvidia/nemotron-nano-9b-v2:free
ENABLE_L2=true
ENABLE_L3=true
MAX_DAILY_LLM_BUDGET_USD=5.00
L1_CONFIDENCE_THRESHOLD=0.8
L2_CONFIDENCE_THRESHOLD=0.7
