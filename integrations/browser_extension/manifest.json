{
  "manifest_version": 3,
  "name": "Sentinel Prompt Guard",
  "version": "0.1.0",
  "description": "Captures employee AI prompts and sends them to Sentinel backend for analysis.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sentinel Prompt Guard"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
